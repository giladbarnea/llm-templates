#!/usr/bin/env bash
# Auto-update external subdirectories after git pull.

set -euo pipefail

# Find repo root in case hook is run from a sub-directory
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "[post-merge] Updating external subdirectories..."

source .githooks/sync-remote-dir.sh

# This will automatically merge updates if they exist
sync_subdir "https://github.com/mattpocock/skills.git" "tdd" "skills/tdd"

echo "[post-merge] Updates complete."
